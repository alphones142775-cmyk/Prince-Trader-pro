style.css

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:#050b14;
  color:white;
  font-family:Arial, sans-serif;
  overflow:hidden;
}

/* TOPBAR */

.topbar{
  height:80px;
  background:#09111f;
  border-bottom:1px solid #122033;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 25px;
}

.logo{
  font-size:34px;
  font-weight:bold;
}

.logo span{
  color:#00ff99;
}

.top-menu{
  display:flex;
  gap:12px;
}

.top-menu button{
  background:transparent;
  border:none;
  color:white;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:5px;
  cursor:pointer;
  padding:10px;
  transition:0.3s;
}

.top-menu button i{
  font-size:22px;
}

.top-menu button:hover,
.top-menu .active{
  color:#00ff99;
}

.profile-section{
  display:flex;
  align-items:center;
  gap:20px;
}

.balance-box{
  text-align:right;
}

.balance-box small{
  color:#00ff99;
}

.profile{
  display:flex;
  align-items:center;
  gap:10px;
}

.profile img{
  width:50px;
  height:50px;
  border-radius:50%;
}

/* DASHBOARD */

.dashboard{
  display:flex;
  height:calc(100vh - 80px);
}

/* SIDEBAR */

.sidebar{
  width:260px;
  background:#08111f;
  border-right:1px solid #122033;
  padding:20px;
}

.user-card{
  background:#0d1728;
  border-radius:20px;
  padding:20px;
  text-align:center;
  margin-bottom:25px;
}

.user-card img{
  width:70px;
  height:70px;
  border-radius:50%;
  margin-bottom:15px;
}

.pro{
  background:#00ff99;
  color:black;
  padding:4px 10px;
  border-radius:10px;
  font-size:12px;
}

.account-balance{
  margin-top:20px;
}

.account-balance h2{
  color:#00ff99;
}

.quick-menu{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.quick-menu button{
  background:#0d1728;
  border:none;
  color:white;
  padding:14px;
  border-radius:12px;
  cursor:pointer;
  transition:0.3s;
}

.quick-menu button:hover,
.menu-active{
  background:#00ff99;
  color:black;
}

/* MAIN CONTENT */

.main-content{
  flex:1;
  padding:20px;
  overflow:auto;
}

.market-strip{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:15px;
  margin-bottom:20px;
}

.market-card{
  background:#0d1728;
  padding:20px;
  border-radius:16px;
}

.market-card span{
  color:#00ff99;
  font-size:20px;
}

.chart-wrapper{
  height:480px;
  background:#0d1728;
  border-radius:20px;
  padding:15px;
  margin-bottom:20px;
}

#chart-container{
  width:100%;
  height:100%;
}

.bottom-panels{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

.panel{
  background:#0d1728;
  padding:20px;
  border-radius:16px;
}

.signal{
  padding:12px;
  margin-top:10px;
  border-radius:10px;
}

.buy{
  background:#00ff9940;
  color:#00ff99;
}

.sell{
  background:#ff003340;
  color:#ff0033;
}

/* TRADE PANEL */

.trade-panel{
  width:320px;
  background:#08111f;
  border-left:1px solid #122033;
  padding:25px;
}

.trade-panel h2{
  margin-bottom:25px;
  color:#00ff99;
}

.trade-panel label{
  display:block;
  margin-bottom:8px;
  margin-top:20px;
}

.trade-panel input,
.trade-panel select{
  width:100%;
  padding:14px;
  background:#0d1728;
  border:none;
  color:white;
  border-radius:12px;
}

.trade-buttons{
  display:flex;
  flex-direction:column;
  gap:15px;
  margin-top:25px;
}

#buyCall{
  background:#00ff99;
  color:black;
}

#buyPut{
  background:#ff0033;
  color:white;
}

.trade-buttons button{
  border:none;
  padding:16px;
  border-radius:12px;
  font-weight:bold;
  cursor:pointer;
}

.trade-info{
  margin-top:30px;
  display:flex;
  justify-content:space-between;
}

